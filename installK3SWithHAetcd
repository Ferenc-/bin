#!/usr/bin/env bash

# You can also start the first server with a predefined secret but this is less secure than the auto generated:
# export SECRET_TOKEN="SECRET-T-12345"
# curl -sfL https://get.k3s.io | INSTALL_K3S_VERSION='v1.20.15+k3s1' K3S_TOKEN="${SECRET_TOKEN}" sh -s - server \

curl -sfL https://get.k3s.io | INSTALL_K3S_VERSION='v1.20.15+k3s1' sh -s - server \
  --cluster-init \
  --kube-apiserver-arg=bind-address=0.0.0.0 \
  --kube-controller-manager-arg=bind-address=0.0.0.0 \
  --kube-scheduler-arg=bind-address=0.0.0.0 \
  --kube-controller-manager-arg=secure-port=10257 \
  --kube-scheduler-arg=secure-port=10259 \
  --etcd-expose-metrics=true

# This is the default port yet, specifiying this errors out with port already in use:
# --kube-apiserver-arg=secure-port=6443 \

# NOTE: Before joining the cluster ensure that the etcd db doesn't contain the node name already:
# You can rm -rf /var/lib/rancher/ on the first node or use the etcdctl
# https://github.com/k3s-io/k3s/issues/10408#issuecomment-2248423815
#
# WARN:
# Unless custom CA certificates are in use, only the short (password-only) token format can be used even
# for adding the second and third node! Ensure that you use cut to get to the autogenerated short token.
# https://docs.k3s.io/cli/token#server

sudo cat /var/lib/rancher/k3s/server/token | cut -d':' -f4
export SECRET_TOKEN=''

curl -sfL https://get.k3s.io | INSTALL_K3S_VERSION='v1.20.15+k3s1' K3S_TOKEN="${SECRET_TOKEN}" sh -s - server \
  --server https://9.60.207.112:6443 \
  --kube-apiserver-arg=bind-address=0.0.0.0 \
  --kube-controller-manager-arg=bind-address=0.0.0.0 \
  --kube-scheduler-arg=bind-address=0.0.0.0 \
  --kube-controller-manager-arg=secure-port=10257 \
  --kube-scheduler-arg=secure-port=10259 \
  --etcd-expose-metrics=true

# This is the default port yet, specifiying this errors out with port already in use:
# --kube-apiserver-arg=secure-port=6443 \

curl -sfL https://get.k3s.io | INSTALL_K3S_VERSION='v1.20.15+k3s1' K3S_TOKEN="${SECRET_TOKEN}" sh -s - server \
  --server https://9.60.207.112:6443 \
  --kube-apiserver-arg=bind-address=0.0.0.0 \
  --kube-controller-manager-arg=bind-address=0.0.0.0 \
  --kube-scheduler-arg=bind-address=0.0.0.0 \
  --kube-controller-manager-arg=secure-port=10257 \
  --kube-scheduler-arg=secure-port=10259 \
  --etcd-expose-metrics=true

