#!/usr/bin/env bash
set -euo pipefail

echo "=== Installing Single-Node Kubernetes Cluster with ETCD Metrics on RedHat ==="

# Disable swap (required for Kubernetes)
echo "Disabling swap..."
swapoff -a
sed -i '/ swap / s/^/#/' /etc/fstab

# Disable SELinux (required for Kubernetes)
echo "Disabling SELinux..."
setenforce 0 || true
if ! grep 'SELINUX=enforcing' /etc/selinux/config; then
  sed -i 's/^SELINUX=enforcing$/SELINUX=disabled/' /etc/selinux/config
fi

# Load required kernel modules
echo "Loading kernel modules..."
cat <<EOF | tee /etc/modules-load.d/k8s.conf
overlay
br_netfilter
EOF

modprobe overlay
modprobe br_netfilter

# Configure sysctl parameters
echo "Configuring sysctl parameters..."
if grep net.ipv4.ip_forward /etc/sysctl.conf; then
  sed -i '/net.ipv4.ip_forward/d' /etc/sysctl.conf
fi
cat <<EOF | tee /etc/sysctl.d/99-k8s.conf
net.bridge.bridge-nf-call-iptables  = 1
net.bridge.bridge-nf-call-ip6tables = 1
net.ipv4.ip_forward                 = 1
EOF

sysctl --system

echo "Adding CRI-O repository"
cat <<EOF | tee /etc/yum.repos.d/cri-o.repo
[cri-o]
name=CRI-O
baseurl=https://download.opensuse.org/repositories/isv:/cri-o:/stable:/v1.36/rpm/
enabled=1
gpgcheck=1
gpgkey=https://download.opensuse.org/repositories/isv:/cri-o:/stable:/v1.36/rpm/repodata/repomd.xml.key
EOF

echo "Adding Kubernetes repository..."
cat <<EOF | sudo tee /etc/yum.repos.d/kubernetes.repo
[kubernetes]
name=Kubernetes
baseurl=https://pkgs.k8s.io/core:/stable:/v1.36/rpm/
enabled=1
gpgcheck=1
gpgkey=https://pkgs.k8s.io/core:/stable:/v1.36/rpm/repodata/repomd.xml.key
exclude=kubelet kubeadm kubectl cri-tools kubernetes-cni
EOF

# Install Kubernetes components
echo "Installing kubeadm, kubelet, and kubectl..."
dnf install -y cri-o kubelet kubeadm kubectl --disableexcludes=kubernetes
systemctl enable --now crio.service
systemctl enable --now kubelet

# Initialize Kubernetes cluster with ETCD metrics enabled
echo "Initializing Kubernetes cluster..."
cat <<EOF >/tmp/kubeadm-config.yaml
apiVersion: kubeadm.k8s.io/v1beta4
kind: ClusterConfiguration
etcd:
  local:
    extraArgs:
    - name: listen-metrics-urls
      value: "http://0.0.0.0:2381"
controllerManager:
  extraArgs:
    - name: bind-address
      value: "0.0.0.0"
scheduler:
  extraArgs:
    - name: bind-address
      value: "0.0.0.0"
EOF

kubeadm init --config=/tmp/kubeadm-config.yaml

# Configure kubectl for root user
echo "Configuring kubectl..."
mkdir -p $HOME/.kube
cp -i /etc/kubernetes/admin.conf $HOME/.kube/config
chown $(id -u):$(id -g) $HOME/.kube/config

# Remove taint to allow scheduling on control plane (single-node setup)
echo "Removing control-plane taint..."
kubectl taint nodes --all node-role.kubernetes.io/control-plane-

## Install Calico CNI
echo "Installing Calico CNI..."
kubectl create -f https://raw.githubusercontent.com/projectcalico/calico/v3.32.0/manifests/calico.yaml
kubectl -n kube-system get pods --watch

# Wait for node to be ready
echo "Waiting for node to be ready..."
kubectl wait --for=condition=Ready nodes --all --timeout=300s

echo ""
echo "=== Installation Complete ==="
echo ""
echo "Cluster Info:"
kubectl cluster-info
echo ""
echo "Node Status:"
kubectl get nodes
echo ""
echo "ETCD metrics are exposed at: http://localhost:2381/metrics"
echo "You can verify with: curl http://localhost:2381/metrics"
